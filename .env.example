# ─── Required ────────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# ─── Sarvam AI (Text-to-Speech for Audio mode) ──────────────────────────────
# Get your key at https://dashboard.sarvam.ai
# Without this key, Audio mode falls back to browser speech synthesis.
SARVAM_API_KEY=your_sarvam_api_key_here

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# DATA_DIR=./data            # Directory for SQLite database (default: ./data)

# ─── Owner Emails (comma-separated, get auto-Pro plan) ─────────────────────
OWNER_EMAILS=prashanth.kubsad@gmail.com,kubsadaadyanth@gmail.com

# ─── AI Queue ────────────────────────────────────────────────────────────────
AI_MAX_CONCURRENT=5        # Max parallel Gemini requests
AI_MAX_QUEUE=50            # Max queued requests before rejecting
AI_TIMEOUT_MS=120000       # Per-request timeout (2 minutes)

# ─── Cache ───────────────────────────────────────────────────────────────────
CACHE_TTL_MS=3600000       # Cache TTL (1 hour)
CACHE_MAX_ENTRIES=200      # Max cached responses

# ─── Authentication ─────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Use a strong random string in production.
JWT_SECRET=change-me-in-production

# ─── Razorpay (Payments) ───────────────────────────────────────────────────
# Get your keys at https://dashboard.razorpay.com/app/keys
# Without these keys, payment endpoints return 503.
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
